    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.14.0",
    "prisma": "^6.0.0",
    "typescript": "5.9.2",
    "tsx": "^4.19.2"
  }
